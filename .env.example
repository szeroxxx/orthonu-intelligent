NODE_ENV=development
PORT=3001

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/orthonu

# Dentira Care API
# Sandbox: vendor-care-sbx.dentira.com (NOT vendor-caresbx — auth spec has a typo)
# Production: vendor.care.dentira.com
DENTIRA_BASE_URL=https://vendor-care-sbx.dentira.com
DENTIRA_CLIENT_ID=ortho_nu
DENTIRA_CLIENT_SECRET=teez5cah5aeRoocup5iet5dip4uuChohTeeraivuji0mei0yahmeiQu1tuawaiph

# Webhook signing secret (pending confirmation from Dentira — stub for now)
DENTIRA_WEBHOOK_SECRET=replace-me-once-dentira-confirms

# JWT for Chrome overlay sessions (generate a strong random secret)
JWT_SECRET=replace-me-with-32-char-minimum-random-secret

# Logging
LOG_LEVEL=info

# Demo mode: simulates SHIPPED/DELIVERED status updates with delays
# Set to "true" in demo environments, "false" in production
DEMO_MODE=true

# ─── Epic CDS Hooks Integration ───────────────────────────────────────────────
# EPIC_ENV controls which client ID is active ('sandbox' | 'production')
EPIC_ENV=sandbox
EPIC_CLIENT_ID_SANDBOX=53f42d61-92ee-4db7-8698-5a27c3db8d4f
EPIC_CLIENT_ID_PRODUCTION=6c2d33c7-024c-43b5-97ff-33568bd0931f

# Epic FHIR base URL (sandbox)
EPIC_FHIR_BASE_URL=https://vendorservices.epic.com/interconnect-amcurprd-oauth

# Epic's JWKS URL — used to verify incoming JWT signatures from Epic.
# Get from Epic sandbox docs (e.g. https://fhir.epic.com/.well-known/jwks)
EPIC_JWKS_URL=

# Epic's iss claim value — must match exactly what Epic sends in JWTs.
# Get from Epic sandbox docs (e.g. https://fhir.epic.com/interconnect-fhir-oauth)
EPIC_EXPECTED_ISS=

# RSA keypair paths — generated with:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out sandbox-private.pem
#   openssl rsa -pubout -in sandbox-private.pem -out sandbox-public.pem
EPIC_PRIVATE_KEY_PATH=/etc/orthonu/keys/sandbox-private.pem
EPIC_PUBLIC_KEY_PATH=/etc/orthonu/keys/sandbox-public.pem
EPIC_KEY_ID=orthonu-sandbox-2026-04

# Public JWKS URL for this service — registered on the Epic portal as "JWK Set URL"
EPIC_CDS_BASE_URL=https://cds.orthonu.com

# SMART launch URL (Phase 3 placeholder — not required for Phase 1 submission)
EPIC_SMART_LAUNCH_URL=https://app.orthonu.com/smart/launch

# Test-only JWKS override (NODE_ENV=test only) — NEVER used in production
# EPIC_TEST_JWKS_URL=http://localhost:3001/.well-known/jwks.json
